# .env.local — SlipMint environment variables
# Copy this into your existing .env.local file
# NEVER commit this file to git — it's already in .gitignore

# ─────────────────────────────────────────────
# EMAIL PROVIDER — choose one: brevo | mailchimp
# ─────────────────────────────────────────────
NEXT_PUBLIC_EMAIL_PROVIDER=brevo


# ─────────────────────────────────────────────
# BREVO (formerly Sendinblue)
# ─────────────────────────────────────────────
# 1. Go to https://app.brevo.com → Settings → API Keys → Generate a new API key
# 2. BREVO_API_KEY = the key you just generated (looks like: xkeysib-abc123...)
# 3. Go to Contacts → Lists → create a "SlipMint Subscribers" list
# 4. BREVO_LIST_ID = the number shown next to the list (e.g. 3)

BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=3


# ─────────────────────────────────────────────
# MAILCHIMP (alternative to Brevo)
# ─────────────────────────────────────────────
# 1. Go to https://mailchimp.com → Account → Extras → API keys → Create A Key
# 2. MAILCHIMP_API_KEY = the key you just created
# 3. MAILCHIMP_SERVER_PREFIX = the prefix in your API endpoint URL (e.g. "us21")
#    Find it: your API key ends with "-us21" → prefix is "us21"
# 4. MAILCHIMP_AUDIENCE_ID = your list/audience ID
#    Find it: Audience → Manage Audience → Settings → Audience ID

MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=your_audience_id_here
